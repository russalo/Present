# infrastructure/.env
# Auto-generated by `just env` (chezmoi template).
# Source: .chezmoi/dot_infrastructure/dot_env.tmpl
#
# DO NOT edit this file directly.
# Edit the template and re-run `just env` to regenerate.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=sentinel_admin
POSTGRES_PASSWORD=sentinel_dev_local
POSTGRES_DB=sentinel_world

# ─── Tailscale Mesh Binding ───────────────────────────────────────────────────
# 127.0.0.1 = local-only dev (no Tailscale required).
# For multi-node deployments, set this to your Infrastructure Node's
# Tailscale IP (100.x.y.z) to restrict DB ports to the mesh network.
TAILSCALE_BIND_IP=127.0.0.1

# ─── Docker Host (OS-specific) ────────────────────────────────────────────────
{{ if eq .chezmoi.os "darwin" -}}
# macOS — Docker Desktop newer versions use a user-space socket.
# Uncomment the line below if `docker compose up` fails with a socket error:
# DOCKER_HOST=unix://${HOME}/.docker/run/docker.sock
{{ else if eq .chezmoi.os "windows" -}}
# Windows — Docker Engine exposes a named pipe over WSL2.
# Uncomment the line below if containers fail to start:
# DOCKER_HOST=npipe:////./pipe/docker_engine
{{ else -}}
# Linux — standard socket path, no override needed.
{{ end -}}

# ─── ChromaDB Auth (disabled for local dev) ───────────────────────────────────
# Enable for strict zero-trust Tailscale deployments only.
CHROMA_AUTH_PROVIDER=
CHROMA_AUTH_CREDENTIALS_FILE=

# ─── MCP Server Ports ─────────────────────────────────────────────────────────
FS_MANAGER_PORT=8010
DB_VECTOR_PORT=8011
GIT_SYNC_PORT=8012

# ─── Inference Node Connection ────────────────────────────────────────────────
# Set INFERENCE_NODE_IP to the Tailscale IP of your MacBook/Inference Node
# when running in split-node mode. 127.0.0.1 = single-machine dev.
INFERENCE_NODE_IP=127.0.0.1
INFERENCE_NODE_CALLBACK_PORT=9000

# ─── Python Binary (OS-specific hint) ────────────────────────────────────────
# Scripts use python3; on Windows/WSL the binary may be `python`.
{{ if eq .chezmoi.os "windows" -}}
PYTHON_BIN=python
{{ else -}}
PYTHON_BIN=python3
{{ end -}}
