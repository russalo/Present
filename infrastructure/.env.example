# -------------------------------------------------------------------
# Project Sentinel — Infrastructure Node Environment Variables
# -------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -------------------------------------------------------------------
# PostgreSQL Credentials
# -------------------------------------------------------------------
POSTGRES_USER=sentinel_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sentinel_world

# -------------------------------------------------------------------
# Tailscale Mesh Binding
# -------------------------------------------------------------------
# Set this to your Infrastructure Node's Tailscale IP (100.x.y.z)
# to restrict database ports exclusively to the mesh network.
# Leave blank or set to 127.0.0.1 for local-only development.
TAILSCALE_BIND_IP=127.0.0.1

# -------------------------------------------------------------------
# ChromaDB Auth (Optional — recommended for multi-user mesh setups)
# -------------------------------------------------------------------
CHROMA_AUTH_PROVIDER=
CHROMA_AUTH_CREDENTIALS_FILE=

# -------------------------------------------------------------------
# MCP Server Ports
# -------------------------------------------------------------------
FS_MANAGER_PORT=8010
DB_VECTOR_PORT=8011
GIT_SYNC_PORT=8012

# -------------------------------------------------------------------
# Inference Node Connection (set on the Infrastructure Node)
# -------------------------------------------------------------------
# The Tailscale IP of the Inference Node (MacBook M3).
# Used by the git-sync MCP to push session notifications.
INFERENCE_NODE_IP=100.x.y.z
INFERENCE_NODE_CALLBACK_PORT=9000

# -------------------------------------------------------------------
# LLM API (set on the Inference Node only — not here)
# -------------------------------------------------------------------
# OPENAI_API_KEY or GEMINI_API_KEY are managed on the Inference Node.
# Do not store API keys on the Infrastructure Node.
